# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=kidaptive

# ── JWT Secrets (change in production!) ───────────────────────────────────────
JWT_SECRET=kidaptive-jwt-secret-change-in-production
JWT_REFRESH_SECRET=kidaptive-refresh-secret-change-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ── Gmail SMTP (App Password required) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kidaptive.app@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Kidaptive <kidaptive.app@gmail.com>"
